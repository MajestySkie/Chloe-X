local function normalize(str)
    str = string.lower(str)
    str = string.gsub(str, "%b[]", "")
    str = string.gsub(str, "[^%w%s]", "")
    str = string.gsub(str, "%s+", " ")
    return str
end

local MarketplaceService = game:GetService("MarketplaceService")

local gameId = game.GameId

if games[gameId] then
    loadstring(game:HttpGet(games[gameId]))()
else
    local success, name = pcall(function()
        return MarketplaceService:GetProductInfo(game.PlaceId).Name
    end)

    if success then
        local lowerName = normalize(name)

        for keyword, url in pairs(subgames) do
            if string.find(lowerName, keyword) then
                loadstring(game:HttpGet(url))()
                return
            end
        end
    end

    game.Players.LocalPlayer:Kick("Yo! This game ain't on the list.\nCheck the Discord for whitelisted games, homie.")
end
