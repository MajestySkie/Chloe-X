    local lowerName = normalize(name)
    print("Detected game:", name)

    local found = false
    for _, gameData in ipairs(games) do
        if matchesAll(lowerName, gameData.keywords) then
            loadstring(game:HttpGet(gameData.url))()
            found = true
            break
        end
    end

    if not found then
        game.Players.LocalPlayer:Kick("Yo! This game ain't on the list.\nCheck the Discord for whitelisted games, homie.")
