    ["fish it"] = "https://raw.githubusercontent.com/MajestySkie/Chloe-X/refs/heads/main/Games/FishIt.lua",
    ["abyss"] = "https://raw.githubusercontent.com/MajestySkie/Chloe-X/refs/heads/main/Games/Abyss.lua",
    ["garden horizon"] = "https://raw.githubusercontent.com/MajestySkie/Chloe-X/refs/heads/main/Games/GardenHorizon.lua",
    ["sawah indo"] = "https://raw.githubusercontent.com/MajestySkie/Chloe-X/refs/heads/main/Games/SawahIndo.lua",
    ["sailor piece"] = "https://raw.githubusercontent.com/MajestySkie/Chloe-X/refs/heads/main/Games/Sailor.lua",
    ["boss rush"] = "https://raw.githubusercontent.com/MajestySkie/Chloe-X/refs/heads/main/Games/Sailor.lua",
    ["infinite tower"] = "https://raw.githubusercontent.com/MajestySkie/Chloe-X/refs/heads/main/Games/Sailor.lua",
    ["shadow dungeon"] = "https://raw.githubusercontent.com/MajestySkie/Chloe-X/refs/heads/main/Games/Sailor.lua",
    ["rune dungeon"] = "https://raw.githubusercontent.com/MajestySkie/Chloe-X/refs/heads/main/Games/Sailor.lua",
    ["double dungeon"] = "https://raw.githubusercontent.com/MajestySkie/Chloe-X/refs/heads/main/Games/Sailor.lua",
}

local MarketplaceService = game:GetService("MarketplaceService")

local success, name = pcall(function()
    return MarketplaceService:GetProductInfo(game.PlaceId).Name
end)

if success then
    local lowerName = string.lower(name)
    print("Detected game:", name)

    local found = false
    for keyword, url in pairs(games) do
        if string.find(lowerName, keyword) then
            loadstring(game:HttpGet(url))()
            found = true
            break
        end
    end

    if not found then
        game.Players.LocalPlayer:Kick("Yo! This game ain't on the list.\nCheck the Discord for whitelisted games, homie.")
    end
else
    game.Players.LocalPlayer:Kick("Failed to get game info.")
end
